{
  "name": "video-downloader-spa-renderer",
  "description": "Renders SPA pages",
  "license": "MIT",
  "scripts": {
    "compile": "tsc && npm run setup-config",
    "compile:watch": "tsc -w",
    "clean": "rimraf build",
    "execute": "node src/main.js",
    "start": "ts-node src/main.ts",
    "setup-config": "cp -r config build/config && npm run build-info",
    "build-info": "ts-node scripts/build-info.ts",
    "clean-compile": "npm run clean && npm run compile",
    "test": "jest --runInBand",
    "lint": "eslint src",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "config": "^4.2.0",
    "express": "^5.2.1",
    "puppeteer": "^24.37.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/config": "^3.3.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.12",
    "@types/supertest": "^6.0.3",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "simple-git": "^3.30.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
