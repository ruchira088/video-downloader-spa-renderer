{
  "name": "health-check-spa",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "VITE_BUILD_TIMESTAMP=$(date -u +'%Y-%m-%dT%H:%M:%SZ') react-router build",
    "start": "VITE_BUILD_TIMESTAMP=$(date -u +'%Y-%m-%dT%H:%M:%SZ') react-router dev",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint app",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write"
  },
  "dependencies": {
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "axios": "^1.13.4",
    "isbot": "^5.1.34",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^8.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.10"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
